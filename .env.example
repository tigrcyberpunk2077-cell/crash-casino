# Скопируй этот файл в .env и заполни значения.

# Токен бота от @BotFather (обязательно)
BOT_TOKEN=

# Провайдер кошелька: faucet (демо, без сети) | ton (реальный TON testnet)
WALLET_PROVIDER=faucet

# Файл базы данных SQLite
DB_PATH=casino.db

# --- Параметры игры ---
FAUCET_AMOUNT=100          # сколько tTON выдаёт кран
FAUCET_COOLDOWN_SEC=21600  # перезарядка крана, сек (6 часов)
MIN_BET=0.1                # минимальная ставка, tTON
MAX_BET=50                 # максимальная ставка, tTON
MULTIPLIER_GROWTH=0.12     # скорость роста множителя (больше = быстрее)

# --- Mini App (веб-приложение в Telegram) ---
WEBAPP_ENABLED=true        # поднимать веб-сервер вместе с ботом
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080
# Публичный https-адрес Mini App (например, от cloudflared). Без него кнопка
# в Telegram не появится, но в браузере на http://localhost:8080 всё работает.
WEBAPP_URL=
# Пускать без Telegram (гостевой режим) — удобно тестить дизайн в браузере.
WEBAPP_ALLOW_GUEST=true
# Режим webhook вместо polling — включай ТОЛЬКО на сервере с публичным https.
# Локально оставляй false (бот сам опрашивает Telegram).
USE_WEBHOOK=false

# --- TON testnet (только при WALLET_PROVIDER=ton) ---
# Сид-фраза (24 слова) горячего кошелька бота. ИСПОЛЬЗУЙ ОТДЕЛЬНЫЙ TESTNET-КОШЕЛЁК!
TON_MNEMONIC=
# Ключ API toncenter testnet (https://testnet.toncenter.com) — желателен, чтобы не упираться в лимиты
TON_API_KEY=
# Минимальная сумма вывода, tTON
TON_MIN_WITHDRAW=1

# --- Постоянная БД (Turso, бесплатно) — чтобы балансы не пропадали на хостинге ---
# Создай бесплатную базу на turso.tech и впиши сюда:
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=


# ============================================================================
#  ИИ-АГЕНТ СЕТКИ КАНАЛОВ (модуль agent/) — сам пишет посты и публикует их
# ============================================================================

# 1) Бот (создай у @BotFather). Он и присылает черновики, и сам постит в каналы.
#    Бота нужно добавить АДМИНОМ в каждый канал (право «Публикация сообщений»).
AGENT_BOT_TOKEN=
# Твой Telegram user-id (узнать: @userinfobot). Только ты одобряешь и управляешь.
AGENT_ADMIN_ID=

# 2) Чем писать тексты:  gemini (бесплатно) | claude (платный API)
LLM_PROVIDER=gemini
# Если gemini — бесплатные ключи с aistudio.google.com/apikey.
# Можно НЕСКОЛЬКО через запятую (с разных аккаунтов) — ротация умножает бесплатный лимит:
GEMINI_API_KEY=
# Список моделей через запятую — перебор при лимите:
GEMINI_MODEL=gemini-flash-latest,gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.5-flash
# Если claude — ключ с console.anthropic.com (отдельная оплата, не входит в Pro):
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# 2b) Голос для видео-фабрики (/factory). Пусто → бесплатный edge-tts (робот).
# ElevenLabs — живой голос (бесплатный лимит ~10k символов/мес): ключ с elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
# Pexels — реальные видео-клипы на фон /factory (бесплатно): ключ с pexels.com/api.
# Пусто → статичные ИИ-картинки.
PEXELS_API_KEY=

# 4) Контент: каналы-персоны. Персона и ниша задаются НА КАЖДЫЙ КАНАЛ
#    (командой /addchannel @канал | ниша | персона). Значения ниже — лишь дефолт.
AGENT_DEFAULT_NICHE=трейдинг для новичков
AGENT_DEFAULT_PERSONA=Алина, 26 — тёплый наставник. Объясняет просто, делится опытом, поддерживает новичков.
# Необязательная ссылка для мягкого призыва (чат/канал/бот). Пусто — без ссылок.
AGENT_CTA_LINK=

# 5) Режим. По умолчанию (false): ТЫ присылаешь боту фото (+ опц. подпись «про что»),
#    он пишет текст и шлёт на одобрение. true: бот сам генерит посты с ИИ-картинкой
#    по расписанию (раздел 7) — фото от тебя не нужны.
AGENT_AUTO=false

# 6) Картинки (для авто-режима и команды /now). При AGENT_AUTO=false к твоим фото
#    картинки не генерятся. Pollinations.ai — бесплатно, без ключа.
AGENT_IMAGES=true
AGENT_MEDIA_DIR=agent_media

# 7) Расписание авто-режима (нужно только при AGENT_AUTO=true)
AGENT_INTERVAL_MIN=180     # минимальный промежуток между постами в канале (минуты)
AGENT_TICK_SEC=60          # как часто планировщик проверяет каналы
AGENT_UTC_OFFSET=3         # твой часовой пояс относительно UTC (Москва = 3)
AGENT_ACTIVE_HOURS=10-23   # постим только в этом окне (локальное время); можно через полночь: 22-2
AGENT_PEAK_HOURS=12,15,19,21   # пиковые часы — постим только в них (пусто = любой час окна)

# 8) Сидинг каналов (необязательно): чтобы каналы не терялись при редеплое на сервере.
# JSON-массив, у каждого канала своя персона. Если канал уже есть в БД — пропускается.
# AGENT_CHANNELS=[{"ref":"@my_channel","niche":"трейдинг для новичков","persona":"Алина, 26, тёплый наставник, объясняет просто","interval":180}]

AGENT_DB_PATH=agent.db


# ============================================================================
#  ЛИЧНЫЙ АВТО-ОТВЕТЧИК (модуль assistant/) — ИИ отвечает друзьям от твоего лица
# ============================================================================
# Свой бот для управления (от @BotFather). Если пусто — берётся AGENT_BOT_TOKEN.
ASSISTANT_BOT_TOKEN=
# Твой аккаунт (userbot) — нужен, чтобы видеть личные чаты с друзьями.
# api_id/api_hash — с my.telegram.org; TG_SESSION — из `python -m assistant.login`.
TG_API_ID=
TG_API_HASH=
TG_PHONE=
TG_SESSION=
ASSISTANT_DB_PATH=assistant.db
# Голос (твой клон) и тексты используют те же ELEVENLABS_API_KEY и GEMINI_API_KEY выше.
