# Скопируй этот файл в .env и заполни значения.

# Токен бота от @BotFather (обязательно)
BOT_TOKEN=

# Провайдер кошелька: faucet (демо, без сети) | ton (реальный TON testnet)
WALLET_PROVIDER=faucet

# Файл базы данных SQLite
DB_PATH=casino.db

# --- Параметры игры ---
FAUCET_AMOUNT=100          # сколько tTON выдаёт кран
FAUCET_COOLDOWN_SEC=21600  # перезарядка крана, сек (6 часов)
MIN_BET=0.1                # минимальная ставка, tTON
MAX_BET=50                 # максимальная ставка, tTON
MULTIPLIER_GROWTH=0.12     # скорость роста множителя (больше = быстрее)

# --- Mini App (веб-приложение в Telegram) ---
WEBAPP_ENABLED=true        # поднимать веб-сервер вместе с ботом
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080
# Публичный https-адрес Mini App (например, от cloudflared). Без него кнопка
# в Telegram не появится, но в браузере на http://localhost:8080 всё работает.
WEBAPP_URL=
# Пускать без Telegram (гостевой режим) — удобно тестить дизайн в браузере.
WEBAPP_ALLOW_GUEST=true
# Режим webhook вместо polling — включай ТОЛЬКО на сервере с публичным https.
# Локально оставляй false (бот сам опрашивает Telegram).
USE_WEBHOOK=false

# --- TON testnet (только при WALLET_PROVIDER=ton) ---
# Сид-фраза (24 слова) горячего кошелька бота. ИСПОЛЬЗУЙ ОТДЕЛЬНЫЙ TESTNET-КОШЕЛЁК!
TON_MNEMONIC=
# Ключ API toncenter testnet (https://testnet.toncenter.com) — желателен, чтобы не упираться в лимиты
TON_API_KEY=
# Минимальная сумма вывода, tTON
TON_MIN_WITHDRAW=1

# --- Постоянная БД (Turso, бесплатно) — чтобы балансы не пропадали на хостинге ---
# Создай бесплатную базу на turso.tech и впиши сюда:
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
